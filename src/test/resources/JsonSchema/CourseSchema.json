}
},
"api": {
"type": "array",
"items": {
"$ref": "#/definitions/course"
}
},
"mobile": {
"type": "array",
"items": {
"$ref": "#/definitions/course"
}
}
}
}
},
"definitions": {
"course": {
"type": "object",
